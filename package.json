{
  "name": "forge-client-obsidian",
  "version": "0.1.0",
  "description": "Obsidian client for Forge.",
  "main": "main.js",
  "scripts": {
    "build": "npx esbuild src/main.ts --bundle --platform=node --external:obsidian --external:@codemirror/view --external:@codemirror/state --format=cjs --outfile=main.js && node scripts/copy-assets.mjs",
    "dev": "npm run build -- --watch",
    "test": "node --test src/*.test.ts",
    "build-manifest": "node scripts/build-manifest.mjs",
    "setup-assets": "node scripts/setup-assets.mjs",
    "sync-engine-bundle": "node scripts/sync-engine-bundle.mjs",
    "release-zip": "node scripts/build-release-zip.mjs"
  },
  "keywords": [],
  "author": "Oded Fuhrmann",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "archiver": "^8.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "html-midi-player": "^1.6.0",
    "pyodide": "^0.29.4",
    "verovio": "^6.1.0"
  }
}
